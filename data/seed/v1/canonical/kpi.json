{
  "definitions": [
    {
      "id": "KPI_DEF_DEFECT_RATE",
      "name": "Defect Rate",
      "scope": "line_per_2h_window",
      "formula": "defective_units / inspected_units"
    },
    {
      "id": "KPI_DEF_FPY",
      "name": "First Pass Yield",
      "scope": "line_per_2h_window",
      "formula": "first_pass_ok_units / total_units"
    },
    {
      "id": "KPI_DEF_DISTURBANCE_DURATION",
      "name": "Disturbance Duration",
      "scope": "asset_per_window",
      "formula": "sum(disturbance_end - disturbance_start)"
    },
    {
      "id": "KPI_DEF_ORDER_DELAY_RISK",
      "name": "Order Delay Risk",
      "scope": "order_current",
      "formula": "rule_based(disturbance + defect_trend + remaining_buffer)"
    }
  ],
